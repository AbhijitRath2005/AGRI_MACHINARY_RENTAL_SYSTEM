# Frontend Environment Variables
# Copy this file to .env and fill in your values

# Backend API URL (for production, update this to your deployed backend URL)
VITE_API_URL=http://localhost:5000/api

# Google Gemini API Key - Get it free from: https://aistudio.google.com/app/apikey
# This powers the AgriBot AI chatbot on the platform
VITE_GEMINI_API_KEY=your_gemini_api_key_here
