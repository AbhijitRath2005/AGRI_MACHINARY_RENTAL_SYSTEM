# Frontend Environment Variables
# Copy this file to .env and fill in your values

# Backend API URL
# Local development: use /api (routes through Vite proxy to http://127.0.0.1:5000)
# Production (Vercel): set this to your Render backend URL e.g. https://agri-rental-backend.onrender.com/api
VITE_API_URL=/api

# Google Gemini API Key - Get it free from: https://aistudio.google.com/app/apikey
# This powers the AgriBot AI chatbot on the platform
VITE_GEMINI_API_KEY=your_gemini_api_key_here
